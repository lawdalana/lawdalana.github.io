/** Clinic and Center Open **/
/* =========================================================
   Clinics & Centers – FINAL (Replace All)
   - Desktop/Tablet: BG image + top fade + clickable overlay
   - Mobile: hide BG image + disable overlay link
   ========================================================= */
.home-clinics__wrapper{
  position: relative;
  width: 100%;
  background-color: #ffffff;
  overflow: visible;
  /* Top fade (ชัดขึ้น แต่ยังเนียน) + image */
  background-image:
    linear-gradient(
      to bottom,
      rgba(255,255,255,0.98) 0%,
      rgba(255,255,255,0.85) 18%,
      rgba(255,255,255,0.55) 32%,
      rgba(255,255,255,0.25) 45%,
      rgba(255,255,255,0) 60%
    ),
    url("https://www.thonburibamrungmuang.com/media/2025/12/info-Banner-AACI.webp");
  background-repeat: no-repeat;
  /* สำคัญมาก */
  background-size: 100% 180px, contain;
  background-position: top left, left bottom;
  min-height: 420px;
}
/* Tablet */
@media (max-width: 1024px){
  .home-clinics__wrapper{
    min-height: 360px;
  }
}
/* Mobile: hide background + disable click layer */
@media (max-width: 768px){
  .home-clinics__wrapper{
    background-image: none !important;
    min-height: auto;
  }
  .home-clinics__bg-link{
    display: none !important;
  }
}
/* Clickable overlay (covers only background area) */
.home-clinics__bg-link{
  position: absolute;
  inset: 0;
  z-index: 1;
  display: block;
}
/* Keep all content above the clickable layer */
.home-clinics__wrapper > *:not(.home-clinics__bg-link){
  position: relative;
  z-index: 2;
}
/* Safety: kill any theme pseudo overlays that caused issues */
.home-clinics__wrapper::before,
.home-clinics__wrapper::after{
  content: none !important;
  display: none !important;
}
/** Clinic and Center Close **/
/* === BMI scale spacing tweaks === */
#thb-bmi .thb-scale { 
  margin: 22px 0 12px;            /* เว้นห่างสเกลจากส่วนบน/ล่าง */
}
#thb-bmi .thb-scale-bar { 
  height: 16px;                    
  gap: 6px;                        /* ระยะห่างแต่ละสี */
}
#thb-bmi .thb-pointer { 
  top: -16px;                      /* ยก "ลูกศร" ให้ห่างจากแถบสีมากขึ้น */
  border-left-width: 8px;          /* ปรับขนาดลูกศรให้สมส่วน */
  border-right-width: 8px;
  border-bottom-width: 12px;
  filter: drop-shadow(0 1px 2px rgba(0,0,0,.18));
}
#thb-bmi .thb-scale-labels { 
  margin-top: 10px;                /* เพิ่มช่องว่างระหว่างแถบสี กับตัวเลขเกณฑ์ */
  padding-top: 0;
  font-size: 12.5px;
}
/* Drop สีไว้อาลัย body {
  filter: grayscale(60%); /* Applies a full grayscale effect 
}
*/
.select2-container--open .select2-dropdown--below {
    border-color: #b3dbf2 !important;
    padding:12px;
    margin-top:-40px;
}
span.select2.select2-container.select2-container--default {
    border: 1px solid #b3dbf2;
    border-radius: 8px;
    padding: 0.5rem 0.4rem;
    font-size: 1rem;
    background: #fff;
    box-sizing: border-box;
    transition: border-color 0.15s ease;
}
body .select2-container .select2-selection--single {
    border:none !important;
    height: auto !important;
}
.select2-container--default .select2-selection--single .select2-selection__arrow {
    top:6px;
    right:6px;
}
.woocommerce-checkout .woocommerce-billing-fields .form-row:has(select:valid) > label { z-index:10; }
body.rtl.home .site-footer #footer-3::before {
    margin-left: 0;
    margin-right: 50%;
    transform: translateX(50%);
}
body.rtl sr7-fonttest-wrap {
    contain: strict;
    left: unset;
      right: -1500px;
