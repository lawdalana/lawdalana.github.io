matches":"a[rel~=\"nofollow\"]"}},{"not":{"selector_matches":".no-prefetch, .no-prefetch a"}}]},"eagerness":"conservative"}]}</script> <style>/* ==== Overlay ครอบเต็มจอ ==== */
    .thb-loading {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(255, 255, 255, .9);
      display: none;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(2px)
    }
    .thb-loading[aria-hidden="false"] {
      display: flex
    }
    /* ==== กล่อง ==== */
    .thb-loading__box {
      min-width: 260px;
      max-width: 90vw;
      padding: 20px 24px;
      border-radius: 12px;
      background: #fff;
      box-shadow: 0 10px 30px rgba(0, 0, 0, .12);
      text-align: center;
      color: #0a66a4;
      font-weight: 600;
      display: flex;
      flex-direction: column;
      gap: 12px
    }
    .thb-loading__title {
      font-size: 18px;
      margin: 0
    }
    .thb-loading__desc {
      font-size: 14px;
      color: #3c5165;
      margin: 0
    }
    /* ==== สปินเนอร์ ==== */
    .thb-spinner {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 4px solid #cfe5f6;
      border-top-color: #0473bb;
      animation: thb-spin .9s linear infinite;
      margin: 0 auto
    }
    @keyframes thb-spin {
      to {
        transform: rotate(360deg)
      }
    }
    /* ปิดสกรอลล์เมื่อเปิด overlay */
    html.thb-no-scroll,
    body.thb-no-scroll {
      overflow: hidden !important
